<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SG Hugelshofen-Dotnacht</title>

<link rel="manifest" href="manifest.json">

<style>
:root{
  --black:#111;
  --yellow:#ffcc00;
  --blue:#1e4fa8;
  --red:#c8102e;
  --bg:#f2f2f2;
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Arial, sans-serif;
}

body{
  background:var(--bg);
  color:#111;
  min-height:100vh;
  display:flex;
  flex-direction:column;
}

header{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:90px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:0 25px;
  background:rgba(0,0,0,0.75);
  backdrop-filter:blur(10px);
  color:white;
  z-index:1000;
}

.logo{
  display:flex;
  align-items:center;
  gap:12px;
}

.logo img{
  height:60px;
}

.burger{
  cursor:pointer;
}

.burger span{
  display:block;
  width:28px;
  height:3px;
  background:white;
  margin:5px 0;
}

nav{
  position:absolute;
  right:20px;
  top:90px;
  background:#111;
  display:none;
  flex-direction:column;
  border-radius:10px;
  overflow:hidden;
}

nav.show{
  display:flex;
}

nav a{
  color:white;
  padding:12px 18px;
  text-decoration:none;
  cursor:pointer;
}

nav a:hover{
  background:var(--yellow);
  color:black;
}

.hero{
  width:100%;
  height:60vh;
  background:url("img/hero.jpg") center/cover no-repeat;
  display:flex;
  align-items:flex-end;
  justify-content:center;
  text-align:center;
  position:relative;
  margin-top:90px;
}

.hero::after{
  content:"";
  position:absolute;
  inset:0;
  background:rgba(0,0,0,0.5);
}

.hero h1{
  position:relative;
  color:white;
  font-size:42px;
  margin-bottom:60px;
}

main{
  flex:1;
}

.page{
  display:none;
  max-width:1100px;
  margin:auto;
  padding:40px 20px;
  animation:fadeIn 0.3s ease;
}

.page.active{
  display:block;
}

.box{
  background:white;
  padding:20px;
  border-radius:12px;
  margin-bottom:20px;
  box-shadow:0 3px 10px rgba(0,0,0,0.1);
  border-left:5px solid var(--blue);
  transition:0.2s;
}

.box:hover{
  transform:translateY(-5px);
  box-shadow:0 10px 24px rgba(0,0,0,0.15);
}

.box.yellow{ border-left-color:var(--yellow); }
.box.red{ border-left-color:var(--red); }
.box.blue{ border-left-color:var(--blue); }

.news-item,
.rangliste-item{
  margin-top:18px;
}

.news-date,
.rangliste-date{
  display:block;
  margin:6px 0 12px;
  opacity:0.65;
}

iframe{
  width:100%;
  height:750px;
  border:none;
  border-radius:10px;
}

form{
  display:flex;
  flex-direction:column;
  gap:10px;
}

input, textarea{
  padding:12px;
  border-radius:8px;
  border:1px solid #ccc;
}

button{
  padding:12px;
  border:none;
  background:var(--black);
  color:white;
  border-radius:8px;
  cursor:pointer;
}

button:hover{
  background:var(--yellow);
  color:black;
}

.gallery{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
  gap:10px;
}

.gallery img{
  width:100%;
  height:180px;
  object-fit:cover;
  border-radius:10px;
  transition:0.2s;
}

.gallery img:hover{
  transform:scale(1.03);
}

footer{
  background:var(--black);
  color:white;
  text-align:center;
  padding:25px;
  margin-top:auto;
}

@keyframes fadeIn{
  from{opacity:0; transform:translateY(10px);}
  to{opacity:1; transform:translateY(0);}
}

@media(max-width:768px){
  header{
    height:80px;
    padding:0 15px;
  }

  .logo img{
    height:52px;
  }

  .logo strong{
    font-size:14px;
  }

  nav{
    top:80px;
    right:10px;
  }

  .hero{
    margin-top:80px;
    height:50vh;
  }

  .hero h1{
    font-size:28px;
    padding:0 20px;
  }

  iframe{
    height:520px;
  }
}
</style>
</head>

<body>

<header>
  <div class="logo">
    <img src="img/logo.jpg" alt="Logo SG Hugelshofen-Dotnacht">
    <strong>SG Hugelshofen-Dotnacht</strong>
  </div>

  <div class="burger" onclick="toggleMenu()" aria-label="Menü öffnen">
    <span></span>
    <span></span>
    <span></span>
  </div>

  <nav id="nav">
    <a onclick="show('home')">Home</a>
    <a onclick="show('news')">News</a>
    <a onclick="show('programm')">Programm</a>
    <a onclick="show('ranglisten')">Ranglisten</a>
    <a onclick="show('galerie')">Galerie</a>
    <a onclick="show('schnuppern')">Schnuppern</a>
    <a onclick="show('kontakt')">Kontakt</a>
    <a href="/admin/">Admin</a>
    <a onclick="show('vorstand')">Vorstand</a>
  </nav>
</header>

<div class="hero">
  <h1>Willkommen im Schützenverein</h1>
</div>

<main>

<section id="home" class="page active">
  <div class="box blue">
    <h2>Willkommen</h2>
    <p>Tradition, Sport und Gemeinschaft seit 1876.</p>
  </div>

  <div class="box yellow">
    <h2>Obligatorische Bundesübung</h2>
    <p>Immer Ostermontag und am letzten Mittwoch im August.</p>
  </div>

  <div class="box red">
    <h2>Aktuelle Vereinsnews</h2>

    {% for post in collections.news %}
      {% if loop.index <= 3 %}
        <div class="box news-item">
          <h3>{{ post.data.title }}</h3>
          <small class="news-date">{{ post.data.date | datum }}</small>
          <div>{{ post.content | safe }}</div>
        </div>
      {% endif %}
    {% else %}
      <p>Noch keine News vorhanden.</p>
    {% endfor %}
  </div>
</section>

<section id="news" class="page">
  <div class="box blue">
    <h2>News</h2>

    {% for post in collections.news %}
      <div class="box news-item">
        <h3>{{ post.data.title }}</h3>
        <small class="news-date">{{ post.data.date | datum }}</small>
        <div>{{ post.content | safe }}</div>
      </div>
    {% else %}
      <p>Noch keine News vorhanden.</p>
    {% endfor %}
  </div>
</section>

<section id="programm" class="page">
  <div class="box yellow">
    <h2>Jahresprogramm</h2>
    <iframe src="pdf/jp-2026.pdf"></iframe>
  </div>
</section>

<section id="ranglisten" class="page">
  <div class="box red">
    <h2>Ranglisten</h2>

    {% for item in collections.ranglisten %}
      <div class="box rangliste-item">
        <h3>{{ item.data.title }}</h3>
        <small class="rangliste-date">{{ item.data.date | datum }}</small>

        {% if item.data.pdf %}
          <iframe src="{{ item.data.pdf }}"></iframe>
        {% endif %}
      </div>
    {% else %}
      <p>Noch keine Ranglisten vorhanden.</p>
    {% endfor %}
  </div>
</section>

<section id="galerie" class="page">
  <div class="box blue">
    <h2>Galerie</h2>

    <div class="gallery">
      {% for bild in collections.galerie %}
        {% if bild.data.image %}
          <img src="{{ bild.data.image }}" alt="{{ bild.data.title }}">
        {% endif %}
      {% else %}
        <p>Noch keine Bilder vorhanden.</p>
      {% endfor %}
    </div>
  </div>
</section>

<section id="schnuppern" class="page">
  <div class="box yellow">
    <h2>Schnupperanfrage</h2>

    <form name="schnuppern" method="POST" data-netlify="true">
      <input type="hidden" name="form-name" value="schnuppern">

      <input type="text" name="name" placeholder="Name" required>
      <input type="email" name="email" placeholder="E-Mail" required>
      <textarea name="message" placeholder="Nachricht"></textarea>

      <button type="submit">Absenden</button>
    </form>
  </div>
</section>

<section id="vorstand" class="page">
  <div class="box blue">
    <h2>Vorstand</h2>

    {% for person in collections.vorstand %}
      <div class="box">
        <h3>{{ person.data.role }}</h3>
        <p><strong>{{ person.data.name }}</strong></p>

        {% if person.data.phone %}
          <p>Telefon: {{ person.data.phone }}</p>
        {% endif %}

        {% if person.data.email %}
          <p>E-Mail: <a href="mailto:{{ person.data.email }}">{{ person.data.email }}</a></p>
        {% endif %}
      </div>
    {% else %}
      <p>Noch keine Vorstandsmitglieder eingetragen.</p>
    {% endfor %}
  </div>
</section>

<section id="kontakt" class="page">
  <div class="box blue">
    <h2>Kontakt</h2>
    <iframe style="height:330px;" src="https://www.google.com/maps?q=Hugelshofen+Schweiz&output=embed"></iframe>
  </div>
</section>

</main>

<footer>
SG Hugelshofen-Dotnacht | © 2026 | seit 1876
</footer>

<script>
function show(id){
  document.querySelectorAll('.page').forEach(function(page){
    page.classList.remove('active');
  });

  document.getElementById(id).classList.add('active');
  document.getElementById('nav').classList.remove('show');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function toggleMenu(){
  document.getElementById('nav').classList.toggle('show');
}
</script>

</body>
</html>
